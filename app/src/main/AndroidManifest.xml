<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
>

    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
            android:allowBackup="true"
            android:dataExtractionRules="@xml/data_extraction_rules"
            android:fullBackupContent="@xml/backup_rules"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:supportsRtl="true"
            android:theme="@style/Theme.Outspoke">
        <activity
                android:name=".settings.SettingsActivity"
                android:exported="true"
                android:theme="@style/Theme.Outspoke">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Deep-link: outspoke://settings/permissions, outspoke://settings/model, etc. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="outspoke" android:host="settings"/>
            </intent-filter>
        </activity>

        <service
                android:name=".ime.OutspokeInputMethodService"
                android:label="@string/ime_name"
                android:permission="android.permission.BIND_INPUT_METHOD"
                android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod"/>
            </intent-filter>
            <meta-data
                    android:name="android.view.im"
                    android:resource="@xml/method"/>
        </service>

        <!-- Foreground service that owns the ParakeetEngine lifecycle -->
        <service
                android:name=".inference.InferenceService"
                android:foregroundServiceType="microphone"
                android:exported="false">
            <!-- Android 14+ foreground service type justification -->
            <meta-data
                android:name="android.app.foregroundServiceType.microphone.justification"
                android:value="Required for real-time speech recognition and transcription." />
        </service>

    </application>

</manifest>
